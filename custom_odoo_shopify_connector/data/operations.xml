<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Crons and operations related to ad-hoc Shopify operations (stock/customer imports, price updates). -->

    <!-- Automatically process pending Shopify Customer Import Queues -->
    <record id="ir_cron_shopify_process_customer_import_queue" model="ir.cron">
        <field name="name">Process Shopify Customer Import Queue</field>
        <field name="model_id" ref="custom_odoo_shopify_connector.model_shopify_customer_import_queue"/>
        <field name="state">code</field>
        <field name="code">model.cron_process_pending_queues()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <!-- Automatically process pending Shopify Price Update Queues -->
    <record id="ir_cron_shopify_process_price_update_queue" model="ir.cron">
        <field name="name">Process Shopify Price Update Queue</field>
        <field name="model_id" ref="custom_odoo_shopify_connector.model_shopify_price_update_queue"/>
        <field name="state">code</field>
        <field name="code">model.cron_process_pending_queues()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <!-- Automatically process pending Shopify Image Update Queues -->
    <record id="ir_cron_shopify_process_image_update_queue" model="ir.cron">
        <field name="name">Process Shopify Image Update Queue</field>
        <field name="model_id" ref="custom_odoo_shopify_connector.model_shopify_image_update_queue"/>
        <field name="state">code</field>
        <field name="code">model.cron_process_pending_queues()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

</odoo>

