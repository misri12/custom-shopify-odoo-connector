<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shopify_customer_import_queue_list" model="ir.ui.view">
        <field name="name">shopify.customer.import.queue.list</field>
        <field name="model">shopify.customer.import.queue</field>
        <field name="arch" type="xml">
            <list string="Shopify Customer Import Queues">
                <field name="name"/>
                <field name="store_id"/>
                <field name="operation_type"/>
                <field name="status"/>
                <field name="records_to_process"/>
                <field name="processed_records"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_customer_import_queue_form" model="ir.ui.view">
        <field name="name">shopify.customer.import.queue.form</field>
        <field name="model">shopify.customer.import.queue</field>
        <field name="arch" type="xml">
            <form string="Shopify Customer Import Queue">
                <sheet>
                    <header>
                        <button name="action_process_manually"
                                string="Process Queue Manually"
                                type="object"
                                class="btn-primary"
                                states="pending,failed"/>
                    </header>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="store_id" readonly="1"/>
                            <field name="operation_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="status" readonly="1"/>
                            <field name="records_to_process" readonly="1"/>
                            <field name="processed_records" readonly="1"/>
                            <field name="error_message" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_customer_import_queue" model="ir.actions.act_window">
        <field name="name">Customer Import Queues</field>
        <field name="res_model">shopify.customer.import.queue</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Legacy Customer Import Queues menu removed; queues are now reachable
         from the enterprise Synchronization / Queues menus in
         views/shopify_menu.xml. -->

</odoo>

