<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_refund_wizard_form" model="ir.ui.view">
        <field name="name">shopify.refund.wizard.form</field>
        <field name="model">shopify.refund.wizard</field>
        <field name="arch" type="xml">
            <form string="Refund in Shopify">
                <sheet>
                    <group>
                        <field name="move_id" readonly="1"/>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="store_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="notify"/>
                    </group>
                    <group>
                        <field name="refund_note" placeholder="Refund note to send to Shopify"/>
                    </group>
                    <footer>
                        <button string="Refund in Shopify"
                                name="action_refund_in_shopify"
                                type="object"
                                class="btn-primary"/>
                        <button string="Close" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

