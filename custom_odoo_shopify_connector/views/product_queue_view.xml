<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List: batch queue records -->
    <record id="view_shopify_product_queue_list" model="ir.ui.view">
        <field name="name">shopify.product.queue.list</field>
        <field name="model">shopify.product.queue</field>
        <field name="arch" type="xml">
            <tree string="Shopify Product Queue">
                <field name="create_date"/>
                <field name="name"/>
                <field name="store_id"/>
                <field name="total_records"/>
                <field name="done_records"/>
                <field name="failed_records"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- List for queue lines: Product Data Line (ID, Product, Last Updated On, Image Import State, State) -->
    <record id="view_shopify_product_queue_line_list" model="ir.ui.view">
        <field name="name">shopify.product.queue.line.list</field>
        <field name="model">shopify.product.queue.line</field>
        <field name="arch" type="xml">
            <tree string="Product Data Line" create="0" delete="0"
                  decoration-success="context.get('state') == 'done'"
                  decoration-danger="context.get('state') == 'failed'">
                <field name="shopify_product_id"/>
                <field name="title"/>
                <field name="write_date" string="Last Updated On"/>
                <field name="image_import_state" widget="badge" decoration-info="context.get('image_import_state') == 'pending'"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- List for Log Lines tab: same lines with Message column -->
    <record id="view_shopify_product_queue_line_log_list" model="ir.ui.view">
        <field name="name">shopify.product.queue.line.log.list</field>
        <field name="model">shopify.product.queue.line</field>
        <field name="arch" type="xml">
            <tree string="Log Lines" create="0" delete="0"
                  decoration-success="context.get('state') == 'done'"
                  decoration-danger="context.get('state') == 'failed'">
                <field name="shopify_product_id"/>
                <field name="title"/>
                <field name="state"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <!-- Form: queue dashboard like screenshot 2 (Instance, Created On, Log Book, Product Data Line / Log Lines) -->
    <record id="view_shopify_product_queue_form" model="ir.ui.view">
        <field name="name">shopify.product.queue.form</field>
        <field name="model">shopify.product.queue</field>
        <field name="arch" type="xml">
            <form string="Shopify Product Queue">
                <header>
                    <button name="action_fetch_products"
                            type="object"
                            string="Fetch Products"
                            class="btn-primary"
                            title="Fetch products from Shopify and add them to this queue"/>
                    <button name="action_process_manually"
                            type="object"
                            string="Process Queue Manually"
                            class="btn-secondary"/>
                    <button name="action_set_to_completed"
                            type="object"
                            string="Set to Completed"
                            invisible="context.get('state') == 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,partial,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Summary">
                            <field name="store_id" readonly="1"/>
                            <field name="create_date" string="Created On" readonly="1"/>
                        </group>
                        <group string="Log Book">
                            <field name="do_not_update_existing"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="total_records" string="Records" readonly="1" class="oe_inline"/>
                            <field name="draft_records" string="Draft" readonly="1" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="failed_records" string="Failed" readonly="1" class="oe_inline"/>
                            <field name="done_records" string="Done" readonly="1" class="oe_inline"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Data Line" name="product_data">
                            <field name="line_ids"/>
                        </page>
                        <page string="Log Lines" name="log_lines">
                            <field name="line_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_product_queue" model="ir.actions.act_window">
        <field name="name">Product Queue</field>
        <field name="res_model">shopify.product.queue</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
