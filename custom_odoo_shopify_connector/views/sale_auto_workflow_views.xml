<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shopify_sale_auto_workflow_tree" model="ir.ui.view">
        <field name="name">shopify.sale.auto.workflow.tree</field>
        <field name="model">shopify.sale.auto.workflow</field>
        <field name="arch" type="xml">
            <tree string="Sales Auto Workflows">
                <field name="name"/>
                <field name="confirm_quotation"/>
                <field name="create_invoice"/>
                <field name="validate_invoice"/>
                <field name="register_payment"/>
                <field name="shipment_policy"/>
            </tree>
        </field>
    </record>

    <record id="view_shopify_sale_auto_workflow_form" model="ir.ui.view">
        <field name="name">shopify.sale.auto.workflow.form</field>
        <field name="model">shopify.sale.auto.workflow</field>
        <field name="arch" type="xml">
            <form string="Shopify Sales Auto Workflow">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="shipment_policy"/>
                        </group>
                    </group>
                    <group string="Order &amp; Invoice">
                        <group>
                            <field name="confirm_quotation"/>
                            <field name="create_invoice"/>
                            <field name="validate_invoice"/>
                            <field name="register_payment"/>
                            <field name="force_accounting_date"/>
                        </group>
                        <group>
                            <field name="sales_journal_id"/>
                            <field name="payment_journal_id"/>
                            <field name="payment_method_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_sale_auto_workflow" model="ir.actions.act_window">
        <field name="name">Sales Auto Workflows</field>
        <field name="res_model">shopify.sale.auto.workflow</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Legacy Sales Auto Workflow menu removed; workflows are now
         accessible under Configuration in views/shopify_menu.xml. -->

</odoo>

