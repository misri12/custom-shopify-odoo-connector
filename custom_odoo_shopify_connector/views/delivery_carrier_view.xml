<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend delivery.carrier form: add Shopify Carrier Info section -->
    <record id="view_delivery_carrier_form_shopify" model="ir.ui.view">
        <field name="name">delivery.carrier.form.shopify</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='description']" position="after">
                <page name="shopify_carrier_info" string="Shopify Carrier Info">
                    <group>
                        <field name="shopify_delivery_source_code" placeholder="e.g. manual"/>
                        <field name="shopify_delivery_code" placeholder="e.g. Standard"/>
                        <field name="shopify_tracking_company" placeholder="e.g. DHL, FedEx, UPS"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
