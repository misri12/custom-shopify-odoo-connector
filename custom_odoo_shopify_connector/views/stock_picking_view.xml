<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Stock Picking form: Update Order Shipping Status button -->
    <record id="view_picking_form_shopify_shipping" model="ir.ui.view">
        <field name="name">stock.picking.form.shopify.shipping</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_update_shopify_shipping_status"
                    type="object"
                    string="Update Order Shipping Status"
                    class="btn-secondary"
                    invisible="state != 'done' or shopify_fulfilled"
                />
            </xpath>
        </field>
    </record>

    <!-- Additional Info tab: Carrier and Tracking Reference (for delivery orders) -->
    <record id="view_picking_form_shopify_additional_info" model="ir.ui.view">
        <field name="name">stock.picking.form.shopify.additional.info</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='extra']" position="inside">
                <group string="Shipping" name="shopify_shipping_info">
                    <field name="carrier_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="carrier_tracking_ref" placeholder="Tracking number"/>
                    <field name="shopify_shipping_status" readonly="1"/>
                    <field name="shopify_fulfilled" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
