<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend stock.quant.package form: Shopify tracking per package (multiple fulfillments) -->
    <record id="view_stock_package_form_shopify" model="ir.ui.view">
        <field name="name">stock.quant.package.form.shopify</field>
        <field name="model">stock.quant.package</field>
        <field name="inherit_id" ref="stock.view_quant_package_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[last()]" position="after">
                <group string="Shopify Tracking (per package)" name="shopify_tracking">
                    <field name="carrier_id" options="{'no_create': True}"/>
                    <field name="carrier_tracking_ref" placeholder="Tracking number for this package"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
