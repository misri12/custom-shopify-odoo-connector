<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_cancel_order_wizard_form" model="ir.ui.view">
        <field name="name">shopify.cancel.order.wizard.form</field>
        <field name="model">shopify.cancel.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Order in Shopify">
                <sheet>
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="store_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="cancel_reason" required="1"/>
                        <field name="email_customer"/>
                    </group>
                    <group>
                        <field name="cancel_message" placeholder="Optional message for internal reference"/>
                    </group>
                    <footer>
                        <button string="Cancel Order in Shopify"
                                name="action_cancel_in_shopify"
                                type="object"
                                class="btn-primary"/>
                        <button string="Close" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

