<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shopify_location_tree" model="ir.ui.view">
        <field name="name">shopify.location.tree</field>
        <field name="model">shopify.location</field>
        <field name="arch" type="xml">
            <list string="Shopify Locations">
                <field name="name"/>
                <field name="shopify_location_id"/>
                <field name="shopify_store_id"/>
                <field name="active"/>
                <field name="warehouse_id"/>
                <field name="order_warehouse_id"/>
                <field name="import_stock_warehouse_id"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_location_form" model="ir.ui.view">
        <field name="name">shopify.location.form</field>
        <field name="model">shopify.location</field>
        <field name="arch" type="xml">
            <form string="Shopify Location">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="shopify_location_id" readonly="1"/>
                            <field name="shopify_store_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group string="Warehouse Mapping">
                            <field name="warehouse_id"/>
                            <field name="order_warehouse_id"/>
                            <field name="import_stock_warehouse_id"/>
                            <field name="export_stock_warehouse_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_location" model="ir.actions.act_window">
        <field name="name">Shopify Locations</field>
        <field name="res_model">shopify.location</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <!-- Legacy Shopify Locations menu removed; Locations now available under
         Configuration in views/shopify_menu.xml. -->

</odoo>

