<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Shopify Product Tag -->
    <record id="view_shopify_product_tag_tree" model="ir.ui.view">
        <field name="name">shopify.product.tag.tree</field>
        <field name="model">shopify.product.tag</field>
        <field name="arch" type="xml">
            <tree string="Shopify Product Tags">
                <field name="name"/>
                <field name="shopify_id"/>
                <field name="instance_id"/>
                <field name="state"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_shopify_product_tag_form" model="ir.ui.view">
        <field name="name">shopify.product.tag.form</field>
        <field name="model">shopify.product.tag</field>
        <field name="arch" type="xml">
            <form string="Shopify Product Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="shopify_id"/>
                        <field name="instance_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shopify_product_tag_search" model="ir.ui.view">
        <field name="name">shopify.product.tag.search</field>
        <field name="model">shopify.product.tag</field>
        <field name="arch" type="xml">
            <search string="Shopify Product Tags">
                <field name="name"/>
                <field name="shopify_id"/>
                <field name="instance_id"/>
                <filter name="state_pending" string="Pending" domain="[('state','=','pending')]"/>
            </search>
        </field>
    </record>

    <record id="action_shopify_product_tag" model="ir.actions.act_window">
        <field name="name">Product Tags</field>
        <field name="res_model">shopify.product.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

