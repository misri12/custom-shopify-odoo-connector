<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shopify_import_queue_list" model="ir.ui.view">
        <field name="name">shopify.import.queue.list</field>
        <field name="model">shopify.import.queue</field>
        <field name="arch" type="xml">
            <tree string="Shopify Import Queue">
                <field name="create_date"/>
                <field name="store_id"/>
                <field name="operation_type"/>
                <field name="status"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="records_to_process"/>
                <field name="processed_records"/>
            </tree>
        </field>
    </record>

    <record id="view_shopify_import_queue_form" model="ir.ui.view">
        <field name="name">shopify.import.queue.form</field>
        <field name="model">shopify.import.queue</field>
        <field name="arch" type="xml">
            <form string="Shopify Import Queue">
                <header>
                    <button name="action_process_queue_manually"
                            type="object"
                            string="Process Queue Manually"
                            class="btn-primary"
                            invisible="context.get('status') != 'pending'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="store_id"/>
                            <field name="operation_type"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="records_to_process" readonly="1"/>
                        <field name="processed_records" readonly="1"/>
                    </group>
                    <group>
                        <field name="error_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_import_queue" model="ir.actions.act_window">
        <field name="name">Import Queue</field>
        <field name="res_model">shopify.import.queue</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

