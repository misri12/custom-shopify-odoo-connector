<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_shopify_refund" model="ir.ui.view">
        <field name="name">account.move.form.shopify.refund</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_shopify_refund_wizard"
                        type="object"
                        string="Refund in Shopify"
                        class="btn-primary"
                        invisible="context.get('move_type') != 'out_refund' or context.get('state') != 'posted' or context.get('payment_state') != 'paid' or context.get('shopify_refunded')"/>
            </xpath>
        </field>
    </record>
</odoo>

