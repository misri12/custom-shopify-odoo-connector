<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Shopify User: can use Shopify features and view logs -->
        <record id="group_shopify_user" model="res.groups">
            <field name="name">Shopify User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can use Shopify connector and view sync logs.</field>
        </record>
        <!-- Shopify Manager: full access to Shopify configuration and logs -->
        <record id="group_shopify_manager" model="res.groups">
            <field name="name">Shopify Manager</field>
            <field name="implied_ids" eval="[(4, ref('custom_odoo_shopify_connector.group_shopify_user'))]"/>
            <field name="comment">Full access to Shopify connector configuration and logs.</field>
        </record>
    </data>
</odoo>
